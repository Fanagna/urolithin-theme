<header class="pm-header" id="pm-header">
  <div class="pm-header-inner">
    <!-- Hamburger (mobile) -->
    <button class="pm-hamburger" id="pm-hamburger" aria-label="Menu" type="button">
      <span></span><span></span><span></span>
    </button>

    <!-- Logo -->
    <div class="pm-logo">
      {% if settings.logo != blank %}
        <a href="{{ routes.root_url }}">
          <img src="{{ settings.logo | img_url: '180x' }}" alt="{{ shop.name }}" loading="eager">
        </a>
      {% else %}
        <a href="{{ routes.root_url }}">{{ shop.name }}</a>
      {% endif %}
    </div>

    <!-- Desktop Navigation -->
    <nav class="pm-nav" id="pm-nav">
      <ul class="pm-nav-list">
        {% for link in linklists[section.settings.main_menu].links %}
          <li class="pm-nav-item {% if link.links != blank %}pm-has-dropdown{% endif %}">
            <a href="{{ link.url }}" class="pm-nav-link">{{ link.title }}</a>
            {% if link.links != blank %}
              <ul class="pm-dropdown">
                {% for child in link.links %}
                  <li><a href="{{ child.url }}">{{ child.title }}</a></li>
                {% endfor %}
              </ul>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>

    <!-- Actions (Search, Cart) -->
    <div class="pm-actions">
      <button class="pm-action-btn pm-search-btn" id="pm-search-btn" aria-label="Search" type="button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
        </svg>
      </button>

      <a href="/cart" class="pm-action-btn pm-cart-btn" id="pm-cart-btn" aria-label="Cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="pm-cart-count" id="pm-cart-count">{% if cart.item_count > 0 %}{{ cart.item_count }}{% endif %}</span>
      </a>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="pm-mobile-menu" id="pm-mobile-menu">
    <ul class="pm-mobile-nav-list">
      {% for link in linklists[section.settings.main_menu].links %}
        <li class="pm-mobile-nav-item">
          <a href="{{ link.url }}" class="pm-mobile-nav-link">{{ link.title }}</a>
          {% if link.links != blank %}
            <ul class="pm-mobile-sublist">
              {% for child in link.links %}
                <li><a href="{{ child.url }}">{{ child.title }}</a></li>
              {% endfor %}
            </ul>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "class": "shopify-section-group-header-group",
  "settings": [
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Main menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
