{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_description = page_description | default: shop.description | default: shop.name

  # Image fallback chain: product/article/page > theme settings > shop logo
  if template.name == 'product' and product.featured_image
    assign og_image = product.featured_image
  elsif article and article.image
    assign og_image = article.image
  elsif page_image
    assign og_image = page_image
  elsif settings.share_image
    assign og_image = settings.share_image
  else
    assign og_image = shop.brand.logo | default: null
  endif

  assign og_url = canonical_url | default: request.origin
-%}

{% comment %}─── Standard Meta ───{% endcomment %}
<meta property="og:locale" content="{{ request.locale.iso_code }}">
<meta property="og:site_name" content="{{ shop.name | escape }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:description" content="{{ og_description | escape }}">
<meta property="og:type" content="{% if template.name == 'product' %}product{% elsif template.name == 'article' %}article{% else %}website{% endif %}">

{%- if og_image -%}
  <meta property="og:image" content="http:{{ og_image | img_url: '1200x630', crop: 'center' }}">
  <meta property="og:image:secure_url" content="https:{{ og_image | img_url: '1200x630', crop: 'center' }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
{%- endif -%}

{% comment %}─── Product-specific OG ───{% endcomment %}
{%- if template.name == 'product' -%}
  <meta property="product:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="product:price:currency" content="{{ shop.currency }}">

  {%- if product.compare_at_price > product.price -%}
    <meta property="product:original_price:amount" content="{{ product.compare_at_price | money_without_currency | strip_html }}">
    <meta property="product:original_price:currency" content="{{ shop.currency }}">
  {%- endif -%}

  {%- if product.available -%}
    <meta property="product:availability" content="in stock">
  {%- else -%}
    <meta property="product:availability" content="out of stock">
  {%- endif -%}

  {%- if product.metafields.reviews.rating -%}
    <meta property="product:rating" content="{{ product.metafields.reviews.rating.value }}">
    <meta property="product:rating:count" content="{{ product.metafields.reviews.rating.count }}">
  {%- endif -%}
{%- endif -%}

{% comment %}─── Twitter Cards ───{% endcomment %}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
{%- if og_image -%}
  <meta name="twitter:image" content="https:{{ og_image | img_url: '1200x600', crop: 'center' }}">
{%- endif -%}

{% comment %}─── JSON-LD BreadcrumbList ───{% endcomment %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ request.origin }}"
    }
    {%- if template.name == 'product' -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ product.title | json }},
        "item": "{{ canonical_url }}"
      }
    {%- elsif template.name == 'collection' -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ collection.title | json }},
        "item": "{{ canonical_url }}"
      }
    {%- endif -%}
  ]
}
</script>

{% comment %}─── JSON-LD Organization ───{% endcomment %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ shop.name | json }},
  "url": {{ request.origin | json }}
  {%- if settings.share_image -%}
    ,"logo": "https:{{ settings.share_image | img_url: 'master' }}"
  {%- endif -%}
}
</script>

{% comment %}─── JSON-LD Product (page produit uniquement) ───{% endcomment %}
{%- if template.name == 'product' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ (page_description | default: product.description | strip_html | truncate: 500) | json }},
  "url": {{ canonical_url | json }},
  "sku": {{ product.sku | default: product.id | json }},
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | json }}
  },
  "offers": [
    {
      "@type": "Offer",
      "price": "{{ product.price | money_without_currency | strip_html }}",
      "priceCurrency": "{{ shop.currency }}",
      "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "url": {{ canonical_url | json }},
      "itemCondition": "https://schema.org/NewCondition"
    }
  ]
  {%- if og_image -%}
    ,"image": ["https:{{ og_image | img_url: 'master' }}"]
  {%- endif -%}
  {%- if product.metafields.reviews.rating -%}
    ,"aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "{{ product.metafields.reviews.rating.value }}",
      "reviewCount": "{{ product.metafields.reviews.rating.count }}"
    }
  {%- endif -%}
}
</script>
{%- endif -%}

{% comment %}─── JSON-LD WebSite (homepage uniquement) ───{% endcomment %}
{%- if template.name == 'index' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": {{ shop.name | json }},
  "url": {{ request.origin | json }},
  "potentialAction": {
    "@type": "SearchAction",
    "target": "{{ request.origin }}/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}
</script>
{%- endif -%}
